#!/bin/sh
# Ensure a git identity is configured before committing.
# The project account is set via the repo's local git config; this guards
# against committing with an unset identity.

actual_name="$(git config user.name)"
actual_email="$(git config user.email)"

if [ -z "$actual_name" ] || [ -z "$actual_email" ]; then
    echo "✖ Commit blocked: no git identity configured for this repo." >&2
    echo "  Found: ${actual_name:-<unset>} <${actual_email:-<unset>}>" >&2
    echo "" >&2
    echo "  Set the project account for this repo:" >&2
    echo "    git config --local user.name  \"Your Name\"" >&2
    echo "    git config --local user.email \"you@example.com\"" >&2
    exit 1
fi
